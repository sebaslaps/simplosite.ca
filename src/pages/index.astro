---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
const mailto = `mailto:${site.email}?subject=${encodeURIComponent('Appel découverte SimploSite')}`;
---
<BaseLayout>
  <section class="hero">
    <div>
      <span class="eyebrow">SimploSite · Sites web pour services locaux</span>
      <h1>Sites web simples pour gens de métier et entreprises de services.</h1>
      <p class="lead">{site.tagline} Vous faites du bon travail. Votre site devrait le dire clairement, sans jargon et sans détour.</p>
      <div class="actions">
        <a class="button primary" href={mailto}>Appel découverte</a>
        <a class="button" href="#contact">Parler de mon site</a>
      </div>
    </div>
    <aside class="hero-card" aria-label="Promesse SimploSite">
      <h2>Un site clair, simple et rassurant.</h2>
      <p class="muted">Pour les clients qui veulent vite comprendre vos services, voir si vous pouvez les aider et savoir comment vous joindre.</p>
      <ul>
        <li>Votre offre expliquée en mots simples</li>
        <li>Une présentation propre qui inspire confiance</li>
        <li>Un chemin facile pour recevoir des demandes</li>
      </ul>
    </aside>
  </section>

  <section class="section" id="services">
    <h2>Ce que SimploSite prépare pour vous</h2>
    <p class="lead">Un site court et efficace pour montrer qui vous aidez, ce que vous faites et pourquoi un client devrait vous contacter.</p>
    <div class="grid">
      {site.services.map((service) => (
        <article class="card">
          <h3>{service}</h3>
          <p class="muted">Pensé pour des entreprises de services qui veulent être prises au sérieux sans se compliquer la vie.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="processus">
    <div class="band">
      <h2>Comment ça marche</h2>
      <div class="grid">
        <article>
          <h3>1. On comprend votre service</h3>
          <p class="muted">Vous expliquez ce que vous faites, votre secteur et le type de client que vous voulez rejoindre.</p>
        </article>
        <article>
          <h3>2. On met vos idées en ordre</h3>
          <p class="muted">On transforme vos services en message simple: quoi, pour qui, dans quelle région et comment vous contacter.</p>
        </article>
        <article>
          <h3>3. Vous révisez avant publication</h3>
          <p class="muted">Vous voyez la page, vous demandez les ajustements, puis on la publie seulement quand vous êtes à l’aise.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Pour qui?</h2>
    <ul class="check-list">
      <li>Entrepreneurs en rénovation, entretien, excavation, nettoyage, réparation ou services à domicile.</li>
      <li>Travailleurs autonomes qui veulent une présence plus crédible qu’une simple page sociale.</li>
      <li>Fournisseurs de services locaux qui veulent que les clients vous trouvent et passent à l’action.</li>
    </ul>
  </section>

  <section class="section" id="contact">
    <div class="contact-card">
      <div>
        <span class="eyebrow">Vous voulez un site plus clair?</span>
        <h2>Parler de mon site</h2>
        <p class="muted">Écrivez à {site.email} avec votre métier, votre région et ce que vous voulez que votre site accomplisse. Téléphone: {site.phoneDisplay}.</p>
      </div>
      <a class="button primary" href={mailto}>Appel découverte</a>
    </div>
  </section>
</BaseLayout>
